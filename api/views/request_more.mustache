<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Request More Time</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: #fff;
            color: #000;
            max-width: 480px;
            margin: 0 auto;
            padding: 0;
            -webkit-text-size-adjust: 100%;
        }
        .header {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 14px 16px;
            border-bottom: 1px solid #f0f0f0;
        }
        .header-logo {
            font-size: 1.25rem;
            font-weight: 700;
            color: #000000;
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .header-logo img {
            width: 28px;
            height: 28px;
            object-fit: contain;
            flex-shrink: 0;
        }
        .section-label {
            font-size: 0.75rem;
            color: #8e8e93;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            padding: 24px 16px 6px;
        }
        .option-list {
            background: #fff;
        }
        .option-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 13px 16px;
            font-size: 1rem;
            cursor: pointer;
            border-bottom: 1px solid #f0f0f0;
            -webkit-tap-highlight-color: transparent;
        }
        .option-item:last-child { border-bottom: none; }
        .option-item.selected .check {
            display: block;
        }
        .option-item .check {
            display: none;
            color: #007aff;
            font-size: 1.2rem;
            font-weight: 600;
        }
        .option-item .label { flex: 1; }
        .sub-panel {
            display: none;
            padding: 10px 16px 14px;
            background: #f9f9fb;
            border-bottom: 1px solid #f0f0f0;
        }
        .sub-panel.visible { display: block; }
        .sub-panel label {
            font-size: 0.8rem;
            color: #8e8e93;
            margin-bottom: 4px;
            display: block;
        }
        .sub-panel .row {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .sub-panel input[type="number"],
        .sub-panel select {
            width: 80px;
            padding: 8px 10px;
            font-size: 1rem;
            border: 1px solid #c7c7cc;
            border-radius: 8px;
            background: #fff;
            text-align: center;
            -webkit-appearance: none;
        }
        .sub-panel .hint {
            font-size: 0.75rem;
            color: #8e8e93;
            margin-top: 4px;
        }
        .notes-section {
            padding: 0;
        }
        .notes-section textarea {
            width: 100%;
            min-height: 120px;
            padding: 12px 16px;
            font-size: 1rem;
            font-family: inherit;
            border: none;
            background: #fff;
            resize: vertical;
            outline: none;
            border-top: 1px solid #f0f0f0;
            border-bottom: 1px solid #f0f0f0;
        }
        .notes-section textarea::placeholder { color: #c7c7cc; }
        .char-count {
            text-align: right;
            font-size: 0.75rem;
            color: #c7c7cc;
            padding: 4px 16px 0;
        }
        .actions {
            padding: 24px 16px 32px;
        }
        .btn-send {
            display: block;
            width: 100%;
            padding: 15px;
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            color: #fff;
            background: #00A1DE;
            cursor: pointer;
            text-align: center;
            -webkit-tap-highlight-color: transparent;
            transition: background 0.15s;
        }
        .btn-send:active { background: #008BC0; }
        .btn-send:disabled { opacity: 0.5; cursor: not-allowed; }
        .btn-cancel {
            display: block;
            width: 100%;
            padding: 15px;
            border: 1.5px solid #00A1DE;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            color: #00A1DE;
            background: transparent;
            cursor: pointer;
            text-align: center;
            margin-top: 10px;
            -webkit-tap-highlight-color: transparent;
            transition: background 0.15s;
        }
        .btn-cancel:active { background: rgba(0, 161, 222, 0.08); }
        .feedback {
            text-align: center;
            font-size: 0.875rem;
            min-height: 1.2em;
            margin-top: 8px;
        }
        .feedback.error { color: #ff3b30; }
        .feedback.success { color: #34c759; }
    </style>
</head>
<body>

<div class="header">
    <div class="header-logo">
        <img src="http://fire.walla:8833/favicon.ico" alt="Avatar">
        Firewalla
    </div>
</div>

<div class="section-label">EXTRA TIME — {{appDisplayName}}</div>
<div class="option-list" id="option-list">
    <div class="option-item selected" data-value="15">
        <span class="label">15 Minutes</span>
        <span class="check">&#10003;</span>
    </div>
    <div class="option-item" data-value="30">
        <span class="label">30 Minutes</span>
        <span class="check">&#10003;</span>
    </div>
    <div class="option-item" data-value="60">
        <span class="label">1 Hour</span>
        <span class="check">&#10003;</span>
    </div>
    <div class="option-item" data-value="for">
        <span class="label">For...</span>
        <span class="check">&#10003;</span>
    </div>
    <div class="sub-panel" id="panel-for">
        <label>Duration (minutes)</label>
        <div class="row">
            <input type="number" id="for-minutes" min="1" max="1440" value="30" inputmode="numeric">
            <span>minutes</span>
        </div>
        <div class="hint" id="for-hint"></div>
    </div>
    <div class="option-item" data-value="until">
        <span class="label">Until...</span>
        <span class="check">&#10003;</span>
    </div>
    <div class="sub-panel" id="panel-until">
        <label>End time (today)</label>
        <div class="row">
            <select id="until-hour"></select>
            <span>:</span>
            <select id="until-minute"></select>
        </div>
        <div class="hint" id="until-hint"></div>
    </div>
</div>

<div class="section-label">NOTES (OPTIONAL)</div>
<div class="notes-section">
    <textarea id="notes" maxlength="256" placeholder=""></textarea>
</div>
<div class="char-count"><span id="char-count">0</span>/256</div>

<div class="actions">
    <button type="button" class="btn-send" id="btn-send">Send</button>
    <button type="button" class="btn-cancel" id="btn-cancel">Cancel</button>
    <div class="feedback" id="feedback"></div>
</div>

<script>
(function() {
    var app = '{{app}}';
    var items = document.querySelectorAll('#option-list .option-item');
    var panelFor = document.getElementById('panel-for');
    var panelUntil = document.getElementById('panel-until');
    var forMinutesInput = document.getElementById('for-minutes');
    var forHint = document.getElementById('for-hint');
    var untilHour = document.getElementById('until-hour');
    var untilMinute = document.getElementById('until-minute');
    var untilHint = document.getElementById('until-hint');
    var notesEl = document.getElementById('notes');
    var charCount = document.getElementById('char-count');
    var btnSend = document.getElementById('btn-send');
    var feedback = document.getElementById('feedback');

    var selected = '15';

    function nowDate() { return new Date(); }

    function minutesLeftToday() {
        var now = nowDate();
        var eod = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 23, 59, 59);
        return Math.max(0, Math.floor((eod - now) / 60000));
    }

    function nextSlot() {
        var now = nowDate();
        var m = now.getMinutes();
        var next = Math.ceil((m + 1) / 5) * 5;
        var d = new Date(now);
        d.setMinutes(next, 0, 0);
        if (next >= 60) { d.setHours(d.getHours() + 1); d.setMinutes(next - 60); }
        return d;
    }

    function populateUntilSelects() {
        var slot = nextSlot();
        var startH = slot.getHours();
        var startM = slot.getMinutes();

        untilHour.innerHTML = '';
        for (var h = startH; h <= 23; h++) {
            var opt = document.createElement('option');
            opt.value = h;
            opt.textContent = h < 10 ? '0' + h : '' + h;
            untilHour.appendChild(opt);
        }

        rebuildMinutes();
    }

    function rebuildMinutes() {
        var slot = nextSlot();
        var selH = parseInt(untilHour.value, 10);
        var minM = (selH === slot.getHours()) ? slot.getMinutes() : 0;
        var prevM = untilMinute.value ? parseInt(untilMinute.value, 10) : -1;

        untilMinute.innerHTML = '';
        for (var m = 0; m < 60; m += 5) {
            if (m < minM) continue;
            var opt = document.createElement('option');
            opt.value = m;
            opt.textContent = m < 10 ? '0' + m : '' + m;
            untilMinute.appendChild(opt);
        }
        if (prevM >= 0) {
            var best = untilMinute.querySelector('option[value="' + prevM + '"]');
            if (best) untilMinute.value = prevM;
        }
        updateUntilHint();
    }

    untilHour.addEventListener('change', rebuildMinutes);
    untilMinute.addEventListener('change', updateUntilHint);

    function updateUntilHint() {
        var mins = calcUntilMinutes();
        untilHint.textContent = mins > 0 ? 'Adds ' + mins + ' minute' + (mins !== 1 ? 's' : '') : 'Select a future time';
    }

    function calcUntilMinutes() {
        var h = parseInt(untilHour.value, 10);
        var m = parseInt(untilMinute.value, 10);
        if (isNaN(h) || isNaN(m)) return 0;
        var target = new Date();
        target.setHours(h, m, 0, 0);
        var diff = Math.floor((target - nowDate()) / 60000);
        return diff > 0 ? diff : 0;
    }

    function updateForHint() {
        var left = minutesLeftToday();
        forHint.textContent = left > 0 ? 'Max ' + left + ' minutes left today' : '';
        forMinutesInput.max = left;
    }

    function selectOption(val) {
        selected = val;
        items.forEach(function(el) {
            el.classList.toggle('selected', el.getAttribute('data-value') === val);
        });
        panelFor.classList.toggle('visible', val === 'for');
        panelUntil.classList.toggle('visible', val === 'until');
        if (val === 'for') updateForHint();
        if (val === 'until') {
            populateUntilSelects();
        }
    }

    items.forEach(function(el) {
        el.addEventListener('click', function() {
            selectOption(el.getAttribute('data-value'));
        });
    });

    notesEl.addEventListener('input', function() {
        charCount.textContent = notesEl.value.length;
    });

    function getMinutesValue() {
        if (selected === 'for') {
            var v = parseInt(forMinutesInput.value, 10);
            var left = minutesLeftToday();
            if (isNaN(v) || v <= 0) return 0;
            return v > left ? left : v;
        }
        if (selected === 'until') {
            return calcUntilMinutes();
        }
        return parseInt(selected, 10);
    }

    btnSend.addEventListener('click', function() {
        var mins = getMinutesValue();
        if (mins <= 0) {
            feedback.className = 'feedback error';
            feedback.textContent = 'Please select a valid time';
            return;
        }
        var payload = { app: app, requestQuota: mins };
        var notes = notesEl.value.trim();
        if (notes) payload.reason = notes;

        btnSend.disabled = true;
        feedback.className = 'feedback';
        feedback.textContent = 'Sending\u2026';

        fetch('/v1/time_limits/requests', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        }).then(function(r) {
            return r.json().then(function(body) {
                if (r.ok) {
                    feedback.className = 'feedback success';
                    feedback.textContent = 'Request sent! Redirecting\u2026';
                    setTimeout(function() {
                        window.location.href = '/v1/time_limits?app=' + encodeURIComponent(app) + '&just_requested=1&from_request=1';
                    }, 800);
                } else {
                    feedback.className = 'feedback error';
                    feedback.textContent = (body && (body.error || body.message)) || 'Request failed';
                    btnSend.disabled = false;
                }
            }).catch(function() {
                if (r.ok) {
                    feedback.className = 'feedback success';
                    feedback.textContent = 'Request sent! Redirecting\u2026';
                    setTimeout(function() {
                        window.location.href = '/v1/time_limits?app=' + encodeURIComponent(app) + '&just_requested=1&from_request=1';
                    }, 800);
                } else {
                    feedback.className = 'feedback error';
                    feedback.textContent = 'Request failed';
                    btnSend.disabled = false;
                }
            });
        }).catch(function() {
            feedback.className = 'feedback error';
            feedback.textContent = 'Network error';
            btnSend.disabled = false;
        });
    });

    document.getElementById('btn-cancel').addEventListener('click', function() {
        window.location.href = '/v1/time_limits?app=' + encodeURIComponent(app);
    });

    selectOption('15');
})();
</script>
</body>
</html>
